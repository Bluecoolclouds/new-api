# ── Telegram Bot ──────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supergroup with Topics (Forum) enabled — paste the chat ID (negative number)
TELEGRAM_SUPPORT_CHAT_ID=-1001234567890

# Comma-separated Telegram user IDs who can reply as admins
# Get your ID from @userinfobot
ADMIN_IDS=123456789,987654321

# ── APINET AI ─────────────────────────────────────────────────
# Server-side API token for calling the AI (never exposed to browser)
WIDGET_TOKEN=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL of APINET instance
APINET_BASE_URL=https://apinet.cloud

# AI model to use for support replies
WIDGET_MODEL=gemini-2.5-flash

# ── HTTP Server ───────────────────────────────────────────────
PORT=3000

# Allowed origin for CORS (your website domain)
# Use * to allow all (not recommended for production)
WIDGET_CORS_ORIGIN=https://apinet.cloud

# Secret for Telegram webhook URL path (makes it hard to guess)
# Generate with: node -e "console.log(require('crypto').randomBytes(20).toString('hex'))"
WEBHOOK_SECRET=change_me_to_random_string
