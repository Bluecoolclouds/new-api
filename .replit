modules = ["go-1.21", "nodejs-20", "web", "go-1.25", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 ./new-api"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["./new-api"]
build = ["bash", "-c", "cd web/default && bun install && DISABLE_ESLINT_PLUGIN=true bun run build; mkdir -p web/classic/dist && [ -f web/classic/dist/index.html ] || printf '<!DOCTYPE html><html><head><title>New API</title></head><body><div id=\"root\"></div></body></html>' > web/classic/dist/index.html; go build -o new-api ."]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
